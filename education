                        y: { 
                            title: { display: true, text: 'リーチ力 (広く浅く)', font: {size: 10} },
                            min: 0, max: 10, ticks: { display: false }
                        }
                    }
                }
            });

            // Chart 2: Funnel & KPI (Bar Chart horizontal representing funnel)
            const ctxFunnel = document.getElementById('kpiFunnelChart').getContext('2d');
            new Chart(ctxFunnel, {
                type: 'bar',
                data: {
                    labels: ['認知 (Awareness)', '興味 (Interest)', '検討 (Consideration)', '購買 (Action)'],
                    datasets: [{
                        label: '重視度合い',
                        data: [100, 75, 50, 25],
                        backgroundColor: [
                            'rgba(99, 102, 241, 0.8)', // Indigo for Awareness
                            'rgba(129, 140, 248, 0.6)', 
                            'rgba(165, 180, 252, 0.4)',
                            'rgba(224, 231, 255, 0.4)'
                        ],
                        borderRadius: 4
                    }]
                },
                options: {
                    indexAxis: 'y', // Horizontal bar
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    const kpis = [
                                        'KPI: リーチ, GRP, インプレッション, ブランド認知度',
                                        'KPI: CTR, サイトセッション数, 検索数(サーチリフト)',
                                        'KPI: 滞在時間, 資料請求数',
                                        'KPI: CVR, CPA, 売上'
                                    ];
                                    return kpis[context.dataIndex];
                                }
                            }
                        }
                    },
                    scales: {
                        x: { display: false, max: 110 },
                        y: { grid: { display: false } }
                    }
                }
            });
        }

        // Run init on load
        window.addEventListener('DOMContentLoaded', init);

    </script>
